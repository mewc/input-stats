  <channel>
    <title>Input Stats</title>
    <!--
      This feed is regenerated on every release by .github/workflows/release.yml: it signs
      InputStats.zip with the EdDSA private key (GitHub secret SPARKLE_PRIVATE_KEY, whose public
      half is SUPublicEDKey in Info.plist) and rewrites the <item> below to point at the new asset.
      The placeholder item carries no <enclosure>, so a client never sees a phantom update until a
      real signed release lands here.
    -->
    <item>
      <title>Version 0.1.4</title>
